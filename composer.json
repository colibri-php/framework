{
    "name": "colibri-php/framework",
    "description": "A lightweight file-based PHP micro-framework",
    "version": "1.0.0-alpha",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-fileinfo": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "catfan/medoo": "^2.2",
        "latte/latte": "^3.1",
        "phpmailer/phpmailer": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "vlucas/valitron": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Colibri\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Colibri\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
